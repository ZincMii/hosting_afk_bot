# Thư mục chứa các thư viện Node.js (Rất nặng, Render sẽ tự tải lại qua 'npm install')
node_modules/

# File nhật ký lỗi khi cài đặt thư viện
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Các file chứa thông tin bảo mật (nếu sau này bạn dùng file .env để giấu mật khẩu bot)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Thư mục cấu hình của các trình mã nguồn (nếu bạn dùng VS Code hoặc WebStorm)
.vscode/
.idea/

# Các file hệ thống tự sinh ra (trên Mac hoặc Windows)
.DS_Store
Thumbs.db